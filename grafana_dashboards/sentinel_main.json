{
    "dashboard": {
        "id": null,
        "title": "Sentinel-1 Master Command",
        "tags": ["security", "ai"],
        "timezone": "browser",
        "panels": [{
                "title": "Neural Engine Health",
                "type": "status-history",
                "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
                "targets": [{ "expr": "layer_status", "refId": "A" }],
                "fieldConfig": {
                    "defaults": {
                        "mappings": [
                            { "type": "value", "options": { "0": { "text": "OFFLINE", "color": "red" }, "1": { "text": "ONLINE", "color": "green" } } }
                        ]
                    }
                }
            },
            {
                "title": "GPU VRAM Usage",
                "type": "gauge",
                "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
                "targets": [{ "expr": "(sentinel_gpu_memory_bytes / gpu_vram_total_bytes) * 100", "refId": "A" }],
                "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 90 }] } } }
            },
            {
                "title": "AI Decision Confidence",
                "type": "stat",
                "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
                "targets": [{ "expr": "avg(sentinel_brain_confidence)", "refId": "A" }],
                "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 0.8 }] } } }
            },
            {
                "title": "Blocked Violations (Safety Cage)",
                "type": "timeseries",
                "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
                "targets": [{ "expr": "sum(increase(sentinel_attack_total{status='blocked'}[1h]))", "refId": "A" }],
                "options": { "legend": { "displayMode": "table" } }
            }
        ],
        "schemaVersion": 36
    }
}